# Required: Slack user token that can read/send your DMs.
SLACK_USER_TOKEN=xoxp-your-user-token

# Required: the Slack member ID this bridge is allowed to answer.
TARGET_USER_ID=U123456789

# Required for Synthetic.
SYNTHETIC_API_KEY=

# Optional: gitignored personal context used so replies can sound like you.
# Create this file locally and add things like your name, preferences, timezone, etc.
IDENTITY_CONTEXT_FILE=.identity-context.txt

# Safe default: generated replies are logged but not sent unless you set DRY_RUN=false.
DRY_RUN=true
